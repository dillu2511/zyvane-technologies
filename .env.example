# ---------------------------------------------------------------------------
# Zyvane Technologies — Environment Variables
# ---------------------------------------------------------------------------
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to version control.

# --- Site ---
# NEXT_PUBLIC_SITE_URL=https://www.zyvanetechnologies.com

# --- Analytics (optional) ---
# NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX
# NEXT_PUBLIC_PLAUSIBLE_DOMAIN=zyvanetechnologies.com

# --- Email / Google Workspace SMTP ---
# MAIL_MAILER=smtp
# MAIL_HOST=smtp.gmail.com
# MAIL_PORT=587
# MAIL_ENCRYPTION=tls
# MAIL_FROM_ADDRESS=raju.kumar@zyvanetechnologies.com
# MAIL_FROM_NAME="Zyvane Technologies"
# MAIL_PASSWORD=your_google_app_password_here

# --- Google Search Console Verification ---
# NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=xxxxxxxxxxxxxxxxxxxxxxx

# --- Maintenance Mode ---
# Set to "true" to enable maintenance mode
MAINTENANCE_MODE=false
# Secret key to bypass maintenance mode (e.g. ?admin_bypass=your_secret_key)
ADMIN_BYPASS_SECRET=zyvaneadmin

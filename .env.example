# ---------------------------------------------------------------------------
# Zyvane Technologies — Environment Variables
# ---------------------------------------------------------------------------
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to version control.

# --- Site ---
NEXT_PUBLIC_SITE_URL=https://www.zyvane.com

# --- Analytics (optional) ---
# NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX
# NEXT_PUBLIC_PLAUSIBLE_DOMAIN=zyvane.com

# --- Email / Contact form (optional) ---
# RESEND_API_KEY=re_xxxxxxxxxxxx
# CONTACT_FORM_TO_EMAIL=hello@zyvane.com

# --- Google Search Console Verification ---
# NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=xxxxxxxxxxxxxxxxxxxxxxx
